{
  "compilerOptions": {
    "lib": ["es5", "es6"],
    "target": "es6",
    "module": "CommonJS",
    "declaration": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "sourceMap": true,
    "outDir": "lib"
  },
  "exclude": ["node_modules", "lib"]
}
